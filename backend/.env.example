# ── Serveur ──────────────────────────────────────────────────
PORT=3001

# ── Sécurité JWT ─────────────────────────────────────────────
# IMPORTANT: Changer ce secret en production (min. 64 caractères aléatoires)
JWT_SECRET=CHANGEZ_CE_SECRET_MINIMUM_64_CARACTERES_RANDOM_EN_PRODUCTION

# ── Admin par défaut ─────────────────────────────────────────
# IMPORTANT: Changer ces valeurs AVANT le lancement
ADMIN_EMAIL=admin@reparationcellordi.ca
ADMIN_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_FORT_EN_PROD
ADMIN_NOM=Administrateur

# ── Notifications Email (Gmail) ─────────────────────────────
# Voir GMAIL_SETUP.md pour créer un mot de passe d'application
GMAIL_USER=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Adresse qui reçoit les alertes admin (nouveaux RDV, messages, etc.)
ADMIN_NOTIFY_EMAIL=admin@reparationcellordi.ca

# ── URL du site ───────────────────────────────────────────────
# En développement: http://localhost:5173
# En production:    https://reparationcellordi.ca
SITE_URL=https://reparationcellordi.ca
